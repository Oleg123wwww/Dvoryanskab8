axed",children:"Будівля є пам'яткою культурної спадщини, включена в списки пам'яток містобудівництва і архітектури місцевого значення та прийнята під охорону держави згідно рішення Одеського облвиконкому №580 від 27.12.1991 р. Охоронний номер — №209-ОД."})]}),r.jsxs("div",{"code-path":"src/sections/About.tsx:140:13",className:"p-4 bg-green-500/10 border border-green-500/20 rounded-xl",children:[r.jsxs("h4",{"code-path":"src/sections/About.tsx:141:15",className:"text-lg font-semibold mb-3 text-green-700 flex items-center gap-2",children:[r.jsx(ni,{"code-path":"src/sections/About.tsx:142:17",className:"w-5 h-5"}),"Відновлення завершено (2026)"]}),r.jsx("p",{"code-path":"src/sections/About.tsx:145:15",className:"text-muted-foreground leading-relaxed mb-4",children:"Внаслідок збройної агресії Російської Федерації будинок зазнав пошкоджень. У 2026 році всі протиаварійні роботи були успішно завершені. Всі мешканці повернулися до своїх квартир!"}),r.jsx("div",{"code-path":"src/sections/About.tsx:150:15",className:"grid sm:grid-cols-2 gap-2",children:p3.slice(0,4).map((c,d)=>r.jsxs("div",{"code-path":"src/sections/About.tsx:152:19",className:"flex items-center gap-2",children:[r.jsx(zd,{"code-path":"src/sections/About.tsx:153:21",className:"w-4 h-4 text-green-500 flex-shrink-0"}),r.jsx("span",{"code-path":"src/sections/About.tsx:154:21",className:"text-sm",children:c})]},d))})]})]})]}),r.jsx("div",{"code-path":"src/sections/About.tsx:163:9",className:`grid grid-cols-2 md:grid-cols-4 gap-4 mb-16 transition-all duration-1000 delay-600 ${l?"opacity-100 translate-y-0":"opacity-0 translate-y-10"}`,children:x3.map((c,d)=>r.jsx(Ie,{"code-path":"src/sections/About.tsx:165:13",className:"card-hover",children:r.jsxs(Je,{"code-path":"src/sections/About.tsx:166:15",className:"p-6 text-center",children:[r.jsx("div",{"code-path":"src/sections/About.tsx:167:17",className:"text-3xl md:text-4xl font-bold gradient-text mb-2",children:c.value}),r.jsx("div",{"code-path":"src/sections/About.tsx